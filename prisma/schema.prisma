generator client {
  provider  = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider  = "postgresql"
}

model UserRead {
  id String @id @default(uuid())
  authorName String?
  authorId String
  kanji String
  read String
  good String[]
  createdAt DateTime @default(now())
  @@index([authorId])
}
